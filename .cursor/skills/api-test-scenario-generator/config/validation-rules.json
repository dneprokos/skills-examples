{
  "inputValidation": {
    "stringFields": {
      "maxLength": 255,
      "minLength": 1,
      "patterns": ["email", "url", "phone", "uuid"]
    },
    "numericFields": {
      "integerRange": [-2147483648, 2147483647],
      "positiveInteger": [1, 2147483647],
      "floatRange": [-3.4e38, 3.4e38]
    },
    "dateFields": {
      "formats": ["ISO8601", "RFC3339"],
      "futureOnly": false,
      "pastOnly": false
    },
    "arrayFields": {
      "maxItems": 100,
      "minItems": 0,
      "uniqueItems": true
    }
  },
  "authenticationTypes": [
    "Bearer token",
    "API key",
    "Basic auth",
    "OAuth 2.0",
    "JWT",
    "None"
  ],
  "authorizationModels": {
    "rbacRoles": ["Admin", "Manager", "Customer", "Guest"],
    "commonPolicies": [
      "owner-only access",
      "admin override",
      "same-tenant isolation",
      "read-all but write-own"
    ]
  },
  "queryCapabilities": {
    "pagination": ["page", "limit", "cursor"],
    "filters": ["exact match", "partial match", "date range", "status"],
    "sorting": ["asc", "desc", "multi-column"],
    "invalidCases": ["unknown filter field", "unknown sort field", "invalid date range"]
  },
  "stateMachinePatterns": {
    "defaultStates": ["PENDING", "CONFIRMED", "SHIPPED", "DELIVERED", "CANCELLED"],
    "checks": [
      "valid transition",
      "invalid backward transition",
      "terminal state cannot change",
      "audit trail preserved"
    ]
  },
  "idempotency": {
    "header": "Idempotency-Key",
    "appliesTo": ["POST", "PUT"],
    "checks": [
      "replayed request does not create duplicate record",
      "same key returns same outcome",
      "conflicting payload with same key is rejected"
    ]
  },
  "errorResponseStructure": {
    "requiredFields": ["error.code", "error.message", "error.requestId"],
    "optionalFields": ["details", "traceId", "violations[]"]
  },
  "dataEdgeCases": {
    "strings": ["Unicode text", "emoji", "whitespace-only string"],
    "numbers": ["0", "negative value", "very large number"],
    "objects": ["unknown fields", "null nested object", "missing nested object"]
  },
  "relationshipChecks": [
    "referential integrity",
    "cascade delete/update behavior",
    "blocked delete when child records exist"
  ],
  "commonErrorCodes": {
    "400": "Bad Request - Invalid input data",
    "401": "Unauthorized - Authentication required",
    "403": "Forbidden - Insufficient permissions",
    "404": "Not Found - Resource does not exist",
    "405": "Method Not Allowed - HTTP method is unsupported for this endpoint",
    "409": "Conflict - Resource already exists or state conflict",
    "415": "Unsupported Media Type - Request content type is not accepted",
    "422": "Unprocessable Entity - Validation failed",
    "429": "Too Many Requests - Rate limiting",
    "500": "Internal Server Error - Server error",
    "502": "Bad Gateway - Upstream dependency failed",
    "503": "Service Unavailable - Temporary outage or maintenance"
  },
  "httpMethods": {
    "GET": {
      "idempotent": true,
      "safe": true,
      "expectedCodes": [200, 400, 401, 403, 404, 429, 502, 503]
    },
    "POST": {
      "idempotent": false,
      "safe": false,
      "expectedCodes": [201, 400, 401, 403, 409, 415, 422, 429, 502, 503]
    },
    "PUT": {
      "idempotent": true,
      "safe": false,
      "expectedCodes": [200, 204, 400, 401, 403, 404, 409, 415, 422, 429, 502, 503]
    },
    "PATCH": {
      "idempotent": false,
      "safe": false,
      "expectedCodes": [200, 204, 400, 401, 403, 404, 409, 415, 422, 429, 502, 503]
    },
    "DELETE": {
      "idempotent": true,
      "safe": false,
      "expectedCodes": [200, 204, 401, 403, 404, 409, 429, 502, 503]
    },
    "HEAD": {
      "idempotent": true,
      "safe": true,
      "expectedCodes": [200, 401, 403, 404, 405]
    },
    "OPTIONS": {
      "idempotent": true,
      "safe": true,
      "expectedCodes": [200, 204, 401, 403, 405]
    }
  }
}
